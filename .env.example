# ============================================================
# AI Platform — Root Secrets Template
# ============================================================
# Copy this file to .env (root) or to the relevant component
# directory and fill in real values.
# .env files are gitignored. This file is safe to commit.
# ============================================================

# ------------------------------------------------------------
# Harness Module (harness_module/.env)
# The API key the harness uses to authenticate with any module.
# Use the same key across all pods for simplicity, or rotate per-pod.
# ------------------------------------------------------------
HARNESS_API_KEY=

# Backend type for this module instance: ollama | comfyui
HARNESS_BACKEND_TYPE=ollama

# Ollama endpoint (local or pod-internal)
HARNESS_OLLAMA_BASE_URL=http://localhost:11434

# ComfyUI endpoint (when BACKEND_TYPE=comfyui)
HARNESS_COMFYUI_BASE_URL=http://localhost:8188

# Path to persistent storage (network volume mount or local)
HARNESS_STORAGE_PATH=./storage

# Module server config
HARNESS_HOST=0.0.0.0
HARNESS_PORT=8080
HARNESS_LOG_LEVEL=info
HARNESS_TEST_MODE=false

# ------------------------------------------------------------
# Cloud API Keys (future — used by Model Router cloud adapters)
# ------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ------------------------------------------------------------
# RunPod (future — used by harness for pod lifecycle management)
# ------------------------------------------------------------
RUNPOD_API_KEY=

# ------------------------------------------------------------
# Frontend Config (frontend/.env or app config)
# The frontend stores these locally, not in the repo.
# See: frontend/src-tauri/config.example.json
# ------------------------------------------------------------
# MODULE_URL=http://127.0.0.1:8080
# MODULE_API_KEY=
