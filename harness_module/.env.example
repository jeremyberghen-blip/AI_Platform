# Required
HARNESS_API_KEY=change-me-before-deploying

# Backend type: ollama | comfyui
HARNESS_BACKEND_TYPE=ollama

# Ollama settings (when BACKEND_TYPE=ollama)
HARNESS_OLLAMA_BASE_URL=http://localhost:11434

# ComfyUI settings (when BACKEND_TYPE=comfyui)
HARNESS_COMFYUI_BASE_URL=http://localhost:8188

# Storage: path to write session logs, thought logs, and media catalog.
# Local: point to the project logs/ folder (relative to harness_module/)
# RunPod: set automatically by entrypoint.sh to /workspace/harness_storage
HARNESS_STORAGE_PATH=../logs

# Server
HARNESS_HOST=0.0.0.0
HARNESS_PORT=8080
HARNESS_LOG_LEVEL=info

# Enable test/inspection mode at startup (can also be toggled via API)
HARNESS_TEST_MODE=false
