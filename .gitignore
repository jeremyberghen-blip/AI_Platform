# ============================================================
# SECRETS — never commit real credentials
# ============================================================
# The pattern: commit *.env.example, never commit *.env
.env
*.env
!*.env.example

# Root-level secrets file (if used as alternative to .env)
secrets.json
secrets.local.json
config.local.json

# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
env/
pip-log.txt
pip-delete-this-directory.txt
.mypy_cache/
.ruff_cache/
.pytest_cache/
*.coverage
htmlcov/

# ============================================================
# Module runtime data — sensitive and large
# ============================================================
# Chat logs, captures, session data, model telemetry
harness_module/storage/

# SQLite databases (contain session data)
*.db
*.sqlite
*.sqlite3

